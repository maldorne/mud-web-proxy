  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/sinon": "^21.0.1",
    "@types/ws": "^8.18.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-chai-expect": "^4.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.2",
    "sinon": "^21.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
